@model Customer

@{
    ViewData["Title"] = "CustomerGetByCity";
    Layout = "~/Views/Layout/Index.cshtml";
}


<div class="row">
    <div class="col-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Şehre Göre Müşteri Kontrolü</h3>
                <form asp-action="CustomerGetByCity" class="forms-sample" method="get">
                    <div class="form-group">
                        <label for="exampleInputName1">Şehir Adı Giriniz</label>
                        <input type="text" class="form-control" id="exampleInputName1" placeholder="Şehir Yazınız"
                               name="city" required >
                    </div>
                    <button type="submit" class="btn btn-primary mr-2">Müşteri Şehir Sorgula</button>
                </form>
                <br />
                <div class="alert alert-success">@ViewBag.message</div>
            </div>
        </div>
    </div>
</div>
