@model List<string>
@{
	ViewData["Title"] = "IncompleteTask";
	Layout = "~/Views/Layout/Index.cshtml";
}
<div class="row">
	<div class="col-lg-12 grid-margin stretch-card">
		<div class="card">
			<div class="card-body">
				<h3 class="card-title">Append ile gün sonu kontrolü</h3>
				<div class="table-responsive">
					<table class="table">
						<thead>
							<tr>
								<th>#</th>
								<th>Açklama</th>

							</tr>
						</thead>
						<tbody>
							@foreach (var item in Model)
							{
								<tr>

									<td>@item</td>

								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
</div>


