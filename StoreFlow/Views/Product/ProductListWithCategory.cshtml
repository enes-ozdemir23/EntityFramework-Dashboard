@model List<ProductWithCategoryViewModel>
@{
    ViewData["Title"] = "ProductListWithCategory";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="row">
	<div class="col-lg-12 grid-margin stretch-card">
		<div class="card">
			<div class="card-body">
				<h3 class="card-title">Ürün Listesi Kategori ile</h3>
				<div class="table-responsive">
					<table class="table">
						<thead>
							<tr>
								<th>Ürün Adı</th>
								<th>Stok Sayısı</th>
								<th>Kategori</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var item in Model)
							{
								<tr>
									<th>@item.ProductName</th>
									<td>@item.ProductStock</td>
									<td>@item.CategoryName</td>

								</tr>
							}
						</tbody>
					</table>
					<a href="/Product/CreateProduct/" class="btn btn-outline-primary">Yeni Ürün Girişi</a>
				</div>
			</div>
		</div>
	</div>
</div>

